{
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.4",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "doctrine/annotations": "^2.0",
        "doctrine/dbal": "^4.2",
        "doctrine/doctrine-bundle": "^3.2",
        "doctrine/doctrine-migrations-bundle": "^3.4",
        "doctrine/orm": "^3.6",
        "eluceo/ical": "^2.16",
        "fakerphp/faker": "^1.21",
        "phpdocumentor/reflection-docblock": "^5.3",
        "phpstan/phpdoc-parser": "^2.0",
        "ramsey/uuid": "^4.9",
        "symfony/apache-pack": "^1.0",
        "symfony/asset": "^8.0",
        "symfony/console": "^8.0",
        "symfony/doctrine-messenger": "^8.0",
        "symfony/dotenv": "^8.0",
        "symfony/expression-language": "^8.0",
        "symfony/flex": "^2",
        "symfony/form": "^8.0",
        "symfony/framework-bundle": "^8.0",
        "symfony/http-client": "^8.0",
        "symfony/intl": "^8.0",
        "symfony/mailer": "^8.0",
        "symfony/mime": "^8.0",
        "symfony/monolog-bundle": "^4.0",
        "symfony/notifier": "^8.0",
        "symfony/process": "^8.0",
        "symfony/property-access": "^8.0",
        "symfony/property-info": "^8.0",
        "symfony/requirements-checker": "^2.0",
        "symfony/runtime": "^8.0",
        "symfony/security-bundle": "^8.0",
        "symfony/serializer": "^8.0",
        "symfony/string": "^8.0",
        "symfony/translation": "^8.0",
        "symfony/twig-bundle": "^8.0",
        "symfony/ux-twig-component": "^2.30",
        "symfony/validator": "^8.0",
        "symfony/web-link": "^8.0",
        "symfony/webpack-encore-bundle": "^2.1",
        "symfony/yaml": "^8.0",
        "twig/extra-bundle": "^3.7.1",
        "twig/intl-extra": "^3.7",
        "twig/twig": "^3.15.0"
    },
    "config": {
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "optimize-autoloader": true,
        "preferred-install": {
            "*": "dist"
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "requirements-checker": "script"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "^8.0"
        }
    },
    "require-dev": {
        "codeception/codeception": "^5.3",
        "codeception/module-asserts": "^3.2",
        "codeception/module-doctrine": "^3.1",
        "codeception/module-phpbrowser": "^4.0",
        "codeception/module-symfony": "^3.8",
        "dama/doctrine-test-bundle": "^8.4",
        "friendsofphp/php-cs-fixer": "^3.91",
        "phpunit/phpunit": "^12.5",
        "squizlabs/php_codesniffer": "^3.11",
        "symfony/browser-kit": "^8.0",
        "symfony/css-selector": "^8.0",
        "symfony/debug-bundle": "^8.0",
        "symfony/maker-bundle": "^1.65",
        "symfony/phpunit-bridge": "^8.0",
        "symfony/stopwatch": "^8.0",
        "symfony/var-dumper": "^8.0",
        "symfony/web-profiler-bundle": "^8.0"
    }
}
